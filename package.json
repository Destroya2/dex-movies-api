{
  "name": "dex-movies-api",
  "version": "1.0.0",
  "description": "Dex Movies — Backend API with HMAC-MD5 scraping",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "vercel-build": "tsc && cp -r dist/api dist/vercel 2>/dev/null; true",
    "test": "cross-env TEST_MODE=true jest",
    "smoke": "tsx tests/smoke.ts",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "@consumet/extensions": "^1.8.8",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "node-cache": "^5.1.2",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.0",
    "@types/supertest": "^7.2.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@vercel/node": "^5.8.23",
    "cross-env": "^10.1.0",
    "jest": "^29.7.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.2.5",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
